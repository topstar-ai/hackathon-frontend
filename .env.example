# ---------------------------------------------------------------------------
# Drift frontend — environment
#
# Leave everything unset to run on the simulated MOCK pipeline (no backend).
# Set the gateway base to drive the REAL Band agents.
# ---------------------------------------------------------------------------

# Public: presence of this flips the app to LIVE mode (used in the browser only
# to decide live-vs-mock and to show the gateway host in the nav).
# Example: https://drift-gateway.example.com
NEXT_PUBLIC_AGENT_API_BASE=

# Server-only: the actual gateway the /api/agent/[slug] proxy forwards to.
# Falls back to NEXT_PUBLIC_AGENT_API_BASE if unset. Keep secrets here, not in
# NEXT_PUBLIC_*.
AGENT_API_BASE=

# Server-only: optional bearer token sent to the gateway by the proxy.
AGENT_API_KEY=
